{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src", "../studio-core/src"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
