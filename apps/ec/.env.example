# POD転売自動化プロジェクト - 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を入力する
# cp .env.example .env
# IMPORTANT: .env はコミットしない（.gitignoreに追加済み）

# === Claude API ===
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# === Shopify ===
# ストアURL（例: mystore.myshopify.com）
SHOPIFY_STORE_URL=your-store.myshopify.com
# Admin API アクセストークン
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx

# === PODtomatic ===
# https://podtomatic.com/ のAPIキー
PODTOMATIC_API_KEY=xxxxxxxxxxxx

# === メルカリ API ===
MERCARI_ACCESS_TOKEN=your_mercari_token_here

# === デフォルト設定 ===
# 出品先プラットフォーム: shopify / mercari / etsy / amazon
TARGET_PLATFORM=shopify
