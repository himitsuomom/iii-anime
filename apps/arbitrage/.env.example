# 越境転売ワーカーの環境変数テンプレート。`.env` にコピーして使う（.env はコミット禁止）。

# iii エンジン接続先（compose では ws://engine:49134）
III_URL=ws://localhost:49134
III_TELEMETRY_ENABLED=false

# Dry-run（空運転）モード。true の間は外部投稿・通知の実呼び出しをしない。
# config/default.yaml の mode.dry_run を上書きする。
ARB_DRY_RUN=true

# Telegram 通知（未設定なら dry-run と同様にプレビューのみ返す）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 為替: Phase 0 は静的レートで代替（後フェーズで live feed に差し替え）
FX_STATIC_RATE=

# 後フェーズ用（Phase 0 では未使用）: eBay 公式 API 認証情報
# EBAY_APP_ID=
# EBAY_CERT_ID=
# EBAY_OAUTH_TOKEN=
