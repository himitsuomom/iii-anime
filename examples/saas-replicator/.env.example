# Engine WebSocket URL (default shown)
III_URL=ws://localhost:49134

# Provider mode:
#   stub = bundled in-process mock provider (no API keys; runs end-to-end)
#   live = call real provider workers (provider-anthropic / provider-kimi)
SAAS_PROVIDER_MODE=stub

# Required only in live mode with provider-anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# App-level token budget (input+output) enforced by the observability decorator.
# 0 or unset = unlimited. Try `SAAS_TOKEN_BUDGET=1 npm run demo` to see the guard.
# SAAS_TOKEN_BUDGET=0
