# freellmapi-worker — API key configuration
# Copy this file to .env and fill in the keys you have.
# At least one key is required for non-keyless endpoints.
# Pollinations is keyless and works without any key.

# Groq — free tier: https://console.groq.com
GROQ_API_KEY=

# Google Gemini — free tier: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Cerebras — free tier: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Mistral — free tier: https://console.mistral.ai
MISTRAL_API_KEY=

# OpenRouter — optional, supports many models
OPENROUTER_API_KEY=

# iii engine WebSocket URL (default: ws://localhost:49134)
# III_URL=ws://localhost:49134
